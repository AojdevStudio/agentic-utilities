{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "AGENTS.md",
      "CHANGELOG.md",
      "README.md",
      "biome.json",
      "package.json",
      "tsconfig.json",
      ".github/**",
      ".coderabbit.yaml",
      "docs/**",
      "extensions/**",
      "prompts/**",
      "rules/**",
      "scripts/**",
      "skills/**",
      "themes/**",
      "!**/node_modules",
      "!**/opensrc"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedFunctionParameters": "off",
        "noUnusedImports": "error",
        "noUnusedVariables": "off"
      },
      "complexity": {
        "noUselessContinue": "off",
        "noUselessEscapeInRegex": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noConsole": "off",
        "noExplicitAny": "off",
        "noUselessEscapeInString": "off"
      }
    },
    "domains": {
      "project": "recommended",
      "test": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "root": true,
  "overrides": [
    {
      "includes": ["extensions/autopilot/v2-smoke-test.mjs"],
      "linter": {
        "domains": {
          "test": "all"
        },
        "rules": {
          "correctness": {
            "noUnusedFunctionParameters": "warn",
            "noUnusedVariables": "warn"
          }
        }
      }
    },
    {
      "includes": ["scripts/**/*.mjs"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedFunctionParameters": "warn",
            "noUnusedVariables": "warn"
          }
        }
      }
    }
  ]
}
