Output docs/assets/hush-demo.gif

Require hush

Set Shell "zsh"
Set FontFamily "SFMono-Regular"
Set FontSize 18
Set Width 1100
Set Height 660
Set Padding 18
Set BorderRadius 12
Set WindowBar Colorful
Set Framerate 15
Set TypingSpeed 90ms
Set Theme { "background": "#0b1020", "foreground": "#e2e8f0", "black": "#111827", "red": "#fb7185", "green": "#4ade80", "yellow": "#facc15", "blue": "#60a5fa", "magenta": "#a78bfa", "cyan": "#22d3ee", "white": "#f8fafc", "brightBlack": "#475569", "brightRed": "#fda4af", "brightGreen": "#86efac", "brightYellow": "#fde047", "brightBlue": "#93c5fd", "brightMagenta": "#c4b5fd", "brightCyan": "#67e8f9", "brightWhite": "#ffffff" }

Type "hush"
Enter
Sleep 1s
Down
Enter
Sleep 1s
Type "STRIPE"
Sleep 1s
Enter
Sleep 1s
Down
Enter
Sleep 2s
Escape
Sleep 500ms
Up
Enter
Sleep 2s
Escape
Escape
